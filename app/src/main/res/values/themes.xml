<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MeerammaTools" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (used in other sections) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color - neutral to match header -->
        <item name="android:statusBarColor">@color/white</item>

        <!-- Make status bar icons dark (for white background) -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>