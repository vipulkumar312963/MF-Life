<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MeerammaTools" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (kept for other sections) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color - dark neutral -->
        <item name="android:statusBarColor">@color/card_background</item>

        <!-- Make status bar icons light (for dark background) -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/black</item>
    </style>
</resources>